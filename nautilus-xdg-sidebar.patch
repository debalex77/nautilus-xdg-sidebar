+static void
+add_user_directory_place (NautilusGtkPlacesSidebar *sidebar,
+                          GUserDirectory             directory,
+                          const char                *label,
+                          const char                *icon_name,
+                          const char                *tooltip)
+{
+  const char *path;
+  char *uri;
+  GIcon *icon;
+
+  path = g_get_user_special_dir (directory);
+
+  /*
+   * An XDG user directory is disabled when it points to the
+   * user's home directory.
+   */
+  if (path == NULL || path_is_home_dir (path))
+    return;
+
+  uri = g_filename_to_uri (path, NULL, NULL);
+  if (uri == NULL)
+    return;
+
+  icon = g_themed_icon_new_with_default_fallbacks (icon_name);
+
+  add_place (sidebar,
+             NAUTILUS_GTK_PLACES_BUILT_IN,
+             NAUTILUS_GTK_PLACES_SECTION_DEFAULT_LOCATIONS,
+             label,
+             icon,
+             NULL,
+             uri,
+             NULL, NULL, NULL, NULL, 0,
+             tooltip);
+
+  g_object_unref (icon);
+  g_free (uri);
+}
+
